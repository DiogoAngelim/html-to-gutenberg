{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "dist",
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": [
      "esnext"
    ],
    "esModuleInterop": true,
  },
  "include": [
    "@types.d.ts",
    "globals.ts",
    "utils.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "vendor",
    "**/*.test.ts",
    "index.ts",
    "fetch-page-assets.test.ts",
    "index.test.ts",
    "coverage-demo.test.ts",
    "snapapi-screenshot.test.ts"
  ]
}
